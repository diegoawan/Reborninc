local RS = game:GetService("ReplicatedStorage")
local Gameplay = RS:WaitForChild("Remotes"):WaitForChild("Gameplay")

local Tabs = {}

local function SafeTab(name)
    local tab = Window:CreateTab(name, 4483362458)
    task.wait(0.15)
    return tab
end

Tabs.Main = SafeTab("Main")
Tabs.Runes = SafeTab("Runes")
Tabs.Upgrades = SafeTab("Upgrades")

task.wait(0.2)

local AutoTier = false
Tabs.Main:CreateToggle({
    Name = "Auto Tier",
    CurrentValue = false,
    Callback = function(v)
        AutoTier = v
        if v then
            task.spawn(function()
                while AutoTier do
                    Gameplay.TierUp:FireServer()
                    task.wait()
                end
            end)
        end
    end
})

task.wait(0.05)

