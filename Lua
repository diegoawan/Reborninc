local AutoTier = false
Tab1:CreateToggle({
    Name = "Auto Tier",
    CurrentValue = false,
    Callback = function(Value)
        AutoTier = Value
        if AutoTier then
            task.spawn(function()
                while AutoTier do
                    RS:WaitForChild("Remotes"):WaitForChild("Gameplay"):WaitForChild("TierUp"):FireServer()
