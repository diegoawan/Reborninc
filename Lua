-- General upgrades
local function CreateUpgradeToggle(typeName, maxLevel)
    UpgradeStates[typeName] = false

    Tab3:CreateToggle({
        Name = "Auto " .. typeName,
        CurrentValue = false,
        Callback = function(Value)
            UpgradeStates[typeName] = Value
            if Value then
                task.spawn(function()
                    while UpgradeStates[typeName] do
                        for level = 1, maxLevel do
                            Gameplay.Upgrade:FireServer(typeName, level, true)
                            task.wait(0.1)
                        end
                        task.wait(0.2)
                    end
                end)
            end
        end
    })

    task.wait(0.05)
end

local Upgrades = {
    {"Energy",5},
    {"Flux",5},
    {"Infinitum",5},
    {"Aetherum",5},
    {"Bubbles",6},
    {"Water",6},
    {"Ice",8},
    {"Fish",8}
}

for _, upg in ipairs(Upgrades) do
    CreateUpgradeToggle(upg[1], upg[2])
end
