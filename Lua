VoltageToggle("MoreVoltage")
VoltageToggle("FasterGain")

local function UpgradeToggle(t, max)
    UpgradeStates[t] = false
    Tabs.Upgrades:CreateToggle({
        Name = "Auto " .. t,
        CurrentValue = false,
        Callback = function(v)
            UpgradeStates[t] = v
            if v then
                task.spawn(function()
                    while UpgradeStates[t] do
                        for i = 1, max do
                            Gameplay.Upgrade:FireServer(t, i, true)
                        end
                        task.wait()
                    end
                end)
            end
        end
    })
    task.wait(0.03)
end

for _,u in ipairs({
    {"Energy",5},{"Flux",5},{"Infinitum",5},{"Aetherum",5},
    {"Bubbles",6},{"Water",6},{"Ice",8},{"Fish",8}
}) do
    UpgradeToggle(u[1], u[2])
end
