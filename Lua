local RuneStates = {}

local function RuneToggle(name)
    RuneStates[name] = false
    Tabs.Runes:CreateToggle({
        Name = "Auto " .. name,
        CurrentValue = false,
        Callback = function(v)
            RuneStates[name] = v
            if v then
                task.spawn(function()
                    while RuneStates[name] do
                        Gameplay.RuneOpen:FireServer(name)
                        task.wait()
                    end
                end)
            end
        end
    })
    task.wait(0.03)
end

for _,r in ipairs({"Energy","Flux","Essence","Voltage","10K Event","Bubbles","Water","Depth","Ice","Fish"}) do
    RuneToggle(r)
end

