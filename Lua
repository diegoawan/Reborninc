local function FastRuneToggle(name)
    local toggled = false
    Tab2:CreateToggle({
        Name = "Auto " .. name,
        CurrentValue = false,
        Callback = function(Value)
            toggled = Value
            if toggled then
                task.spawn(function()
                    while toggled do
                        RS:WaitForChild("Remotes"):WaitForChild("Gameplay"):WaitForChild("RuneOpen"):FireServer(name)
                        task.wait()
                    end
                end)
            end
        end
    })
end

