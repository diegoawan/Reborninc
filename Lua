local function CreateUpgradeToggle(upgradeType, maxLevel)
	local enabled = false

	Tab3:CreateToggle({
		Name = "Auto " .. upgradeType .. " Upgrades",
		CurrentValue = false,
		Callback = function(Value)
			enabled = Value

			if enabled then
				task.spawn(function()
					local UpgradeRemote = Gameplay:WaitForChild("Upgrade")

					while enabled do
						for level = 1, maxLevel do
							UpgradeRemote:FireServer(upgradeType, level, true)
							task.wait(0.1)
						end

						task.wait()
					end
				end)
			end
		end
	})
end

