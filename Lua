	Tab2:CreateToggle({
		Name = "Auto " .. name,
		CurrentValue = false,
		Callback = function(Value)
			toggled = Value

			if toggled then
				task.spawn(function()
					local RuneRemote = Gameplay:WaitForChild("RuneOpen")

					while toggled do
						RuneRemote:FireServer(name)
						task.wait()
					end
				end)
			end
		end
	})
end

