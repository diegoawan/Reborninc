local RS = game:GetService("ReplicatedStorage")

local Remotes = RS:WaitForChild("Remotes"):WaitForChild("Gameplay")

local function GetRemote(name)
	return Remotes:WaitForChild(name)
end

local Remote = {
	TierUp = GetRemote("TierUp"),
	Reborn = GetRemote("Reborn"),
	FishClick = GetRemote("FishClick"),
	CollectBubble = GetRemote("CollectBubble"),
	CollectIce = GetRemote("CollectIce"),
	RuneOpen = GetRemote("RuneOpen"),
	VoltageUpgrade = GetRemote("VoltageUpgrade"),
	Upgrade = GetRemote("Upgrade"),
}

local function MakeLoop(fn)
	local active = false

	return function(enabled)
		active = enabled

		if enabled then
			task.spawn(function()
				while active do
					fn()
					task.wait()
				end
			end)
		end
	end
end

local function MakeMultiLoop(threads, fn)
	local active = false

	return function(enabled)
		active = enabled

		if enabled then
			for _ = 1, threads do
				task.spawn(function()
					while active do
						fn()
						task.wait()
					end
				end)
			end
		end
	end
end

