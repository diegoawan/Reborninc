local RS = game:GetService("ReplicatedStorage")
local Tab1 = Window:CreateTab("Main", 4483362458)
local AutoTier = false
Tab1:CreateToggle({
	Name = "Auto Tier",
	CurrentValue = false,
	Callback = function(Value)
		AutoTier = Value
		if AutoTier then
			task.spawn(function()
				while AutoTier do
					RS:WaitForChild("Remotes"):WaitForChild("Gameplay"):WaitForChild("TierUp"):FireServer()
					task.wait()
				end
			end)
		end
	end
})
local AutoReborn = false
Tab1:CreateToggle({
	Name = "Auto Reborn",
	CurrentValue = false,
	Callback = function(Value)
		AutoReborn = Value
		if AutoReborn then
			task.spawn(function()
				while AutoReborn do
					RS:WaitForChild("Remotes"):WaitForChild("Gameplay"):WaitForChild("Reborn"):FireServer("RebornHitbox1")
					task.wait()
				end
			end)
		end
	end
})
local Tab2 = Window:CreateTab("Runes", 4483362458)
local function FastRuneToggle(name)
	local toggled = false
	Tab2:CreateToggle({
		Name = "Auto " .. name,
		CurrentValue = false,
		Callback = function(Value)
			toggled = Value
			if toggled then
				task.spawn(function()
					while toggled do
						RS:WaitForChild("Remotes"):WaitForChild("Gameplay"):WaitForChild("RuneOpen"):FireServer(name)
						task.wait()
					end
				end)
			end
		end
	})
end
