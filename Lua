FastRuneToggle("10K Event")
local Tab3 = Window:CreateTab("Upgrades", 4483362458)
local function UpgradeToggle(name)
	local toggled = false
	Tab3:CreateToggle({
		Name = "Auto " .. name,
		CurrentValue = false,
		Callback = function(Value)
			toggled = Value
			if toggled then
				task.spawn(function()
					while toggled do
						RS:WaitForChild("Remotes"):WaitForChild("Gameplay"):WaitForChild("VoltageUpgrade"):FireServer(name)
						task.wait()
					end
				end)
			end
		end
