end
UpgradeToggle("MoreVoltage")
UpgradeToggle("FasterGain")
local function CreateUpgradeToggle(upgradeType)
	local enabled = false
	Tab3:CreateToggle({
		Name = "Auto " .. upgradeType .. " Upgrades",
		CurrentValue = false,
		Callback = function(Value)
			enabled = Value
			if enabled then
				task.spawn(function()
					while enabled do
						for level = 1, 5 do
							RS:WaitForChild("Remotes"):WaitForChild("Gameplay"):WaitForChild("Upgrade"):FireServer(upgradeType, level, true)
							task.wait(0.1)
						end
						task.wait()
					end
				end)
			end
		end
	})
end
CreateUpgradeToggle("Energy")
CreateUpgradeToggle("Flux")
CreateUpgradeToggle("Infinitum")
CreateUpgradeToggle("Aetherum")
