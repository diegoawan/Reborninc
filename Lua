-- ================= RUNES =================

local RuneStates = {}

local function FastRuneToggle(name)
    RuneStates[name] = false

    Tab2:CreateToggle({
        Name = "Auto " .. name,
        CurrentValue = false,
        Callback = function(Value)
            RuneStates[name] = Value
            if Value then
                task.spawn(function()
                    while RuneStates[name] do
                        Gameplay.RuneOpen:FireServer(name)
                        task.wait(0.1)
                    end
                end)
            end
        end
    })

    task.wait(0.05) -- prevents UI skipping
end

local Runes = {
    "Energy","Flux","Essence","Voltage",
    "10K Event","Bubbles","Water",
    "Depth","Ice","Fish"
}

for _, rune in ipairs(Runes) do
    FastRuneToggle(rune)
end

