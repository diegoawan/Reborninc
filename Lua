local function AddUpgradeToggle(upgradeType, maxLevel)
	local active = false

	Tab3:CreateToggle({
		Name = "Auto " .. upgradeType .. " Upgrades",
		CurrentValue = false,
		Callback = function(enabled)
			active = enabled

			if enabled then
				task.spawn(function()
					while active do
						for level = 1, maxLevel do
							if not active then
								break
							end

							Remote.Upgrade:FireServer(upgradeType, level, true)
							task.wait(0.1)
						end

						task.wait()
					end
				end)
			end
		end,
	})
end

